@model SterlingLams.Web.Areas.Admin.ViewModels.AdminInventoryViewModel
@{
    ViewData["Title"] = "Inventory";
}

<!-- Header bar -->
<div class="flex flex-wrap items-center justify-between gap-3 mb-5">
    <div>
        @if (Model.LastSyncedAt.HasValue)
        {
            <p class="text-xs text-neutral-400">Last ERPNext sync: @Model.LastSyncedAt.Value.ToLocalTime().ToString("dd MMM yyyy HH:mm")</p>
        }
        <p class="text-xs text-neutral-500 mt-0.5">
            <strong>@Model.TotalCount</strong> active products &nbsp;·&nbsp;
            <strong>@Model.Stores.Count</strong> stores
        </p>
    </div>
    <div class="flex gap-2 flex-wrap">
        <!-- Ensure all products have inventory rows -->
        <form asp-area="Admin" asp-controller="Inventory" asp-action="EnsureInventoryRecords" method="post">
            @Html.AntiForgeryToken()
            <button type="submit"
                    class="px-4 py-2 border border-blue-300 text-blue-700 text-xs rounded-sm hover:bg-blue-50 transition-colors">
                ⊕ Create Missing Records
            </button>
        </form>
        <!-- Sync from ERPNext -->
        <form asp-area="Admin" asp-controller="Inventory" asp-action="Sync" method="post">
            @Html.AntiForgeryToken()
            <button type="submit"
                    class="px-4 py-2 bg-neutral-900 text-white text-xs rounded-sm hover:bg-neutral-700 transition-colors">
                ↺ Sync from ERPNext
            </button>
        </form>
    </div>
</div>

<!-- Search -->
<form method="get" class="flex gap-2 mb-4">
    <input type="text" name="q" value="@Model.SearchQuery"
           placeholder="Search products…"
           class="flex-1 max-w-xs border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400" />
    <button type="submit"
            class="px-4 py-2 bg-neutral-900 text-white text-xs rounded-sm hover:bg-neutral-700 transition-colors">
        Search
    </button>
    @if (!string.IsNullOrEmpty(Model.SearchQuery))
    {
        <a asp-area="Admin" asp-controller="Inventory" asp-action="Index"
           class="px-4 py-2 border border-neutral-200 text-neutral-500 text-xs rounded-sm hover:border-neutral-400 transition-colors">
            ✕ Clear
        </a>
    }
</form>

<!-- Legend -->
<div class="flex gap-4 mb-3 text-[11px] text-neutral-400">
    <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-sm bg-red-100 inline-block"></span> Out of stock</span>
    <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-sm bg-amber-100 inline-block"></span> Low stock</span>
    <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-sm bg-neutral-100 inline-block"></span> No record</span>
    <span class="text-neutral-300">— Type a quantity and click Save to update stock</span>
</div>

@if (!Model.Products.Any())
{
    <div class="bg-white rounded-sm border border-neutral-100 p-16 text-center">
        <p class="text-neutral-400 text-sm mb-4">
            @if (string.IsNullOrEmpty(Model.SearchQuery))
            {
                <span>No inventory records yet.</span>
            }
            else
            {
                <span>No products match "@Model.SearchQuery".</span>
            }
        </p>
        <p class="text-xs text-neutral-400 mb-6">
            After importing products, click <strong>⊕ Create Missing Records</strong> above to initialise all stock to zero.
        </p>
    </div>
}
else
{
    <!-- Hidden save forms — one per product row (outside the table to stay valid HTML) -->
    @foreach (var row in Model.Products)
    {
        <form id="inv-@row.ProductId"
              asp-area="Admin" asp-controller="Inventory" asp-action="SetProductStock"
              method="post" style="display:none">
            @Html.AntiForgeryToken()
            <input type="hidden" name="productId" value="@row.ProductId" />
            <input type="hidden" name="q"    value="@Model.SearchQuery" />
            <input type="hidden" name="page" value="@Model.CurrentPage" />
        </form>
    }

    <!-- Inventory grid -->
    <div class="bg-white rounded-sm border border-neutral-100 overflow-x-auto">
        <table class="w-full text-sm min-w-[700px]">
            <thead>
                <tr class="bg-neutral-50 border-b border-neutral-100">
                    <th class="w-12 px-3 py-3"></th>
                    <th class="text-left px-4 py-3 text-xs text-neutral-400 font-medium">Product</th>
                    <th class="text-left px-4 py-3 text-xs text-neutral-400 font-medium">Category</th>
                    <th class="text-center px-4 py-3 text-xs text-neutral-400 font-medium">Total</th>
                    @foreach (var store in Model.Stores)
                    {
                        <th class="text-center px-3 py-3 text-xs text-neutral-400 font-medium whitespace-nowrap">
                            @store.Name.Replace("Sterlin Glams ", "")
                        </th>
                    }
                    <th class="text-center px-4 py-3 text-xs text-neutral-400 font-medium">Save</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-neutral-50">
                @foreach (var row in Model.Products)
                {
                    var total = row.StockByStore.Values.Where(v => v >= 0).Sum();
                    <tr class="hover:bg-neutral-50 transition-colors @(row.HasOutOfStock ? "bg-red-50/30" : row.HasLowStock ? "bg-amber-50/30" : "")">

                        <!-- Thumbnail -->
                        <td class="px-3 py-2">
                            @if (!string.IsNullOrEmpty(row.ImageUrl))
                            {
                                <img src="@row.ImageUrl" alt="@row.ProductName"
                                     class="w-10 h-10 object-cover rounded-sm border border-neutral-100"
                                     onerror="this.style.display='none'" />
                            }
                            else
                            {
                                <div class="w-10 h-10 rounded-sm bg-neutral-100"></div>
                            }
                        </td>

                        <!-- Product name + SKU -->
                        <td class="px-4 py-3">
                            <p class="text-xs font-medium text-neutral-800 leading-snug">@row.ProductName</p>
                            @if (!string.IsNullOrEmpty(row.Sku))
                            {
                                <p class="text-[10px] text-neutral-400 font-mono mt-0.5">@row.Sku</p>
                            }
                        </td>

                        <!-- Category -->
                        <td class="px-4 py-3 text-xs text-neutral-500">@row.CategoryName</td>

                        <!-- Total stock -->
                        <td class="px-4 py-3 text-center">
                            <span class="text-sm font-medium @(total == 0 ? "text-red-600" : total < row.LowStockThreshold * Model.Stores.Count ? "text-amber-600" : "text-neutral-800")">
                                @total
                            </span>
                        </td>

                        <!-- Stock per store — editable inputs -->
                        @foreach (var store in Model.Stores)
                        {
                            var qty = row.StockByStore.TryGetValue(store.Id, out var q2) ? q2 : -1;
                            var cellBg = qty == -1 ? "bg-neutral-50" : qty == 0 ? "bg-red-50" : qty < row.LowStockThreshold ? "bg-amber-50" : "";
                            <td class="px-3 py-2 text-center @cellBg">
                                @if (qty == -1)
                                {
                                    <!-- No record exists — show dash, still let admin enter a value -->
                                    <input form="inv-@row.ProductId"
                                           type="number" name="store_@store.Id"
                                           placeholder="—" min="0"
                                           class="w-16 text-center text-xs border border-neutral-200 rounded-sm px-2 py-1 focus:outline-none focus:border-neutral-400 bg-white" />
                                }
                                else
                                {
                                    <input form="inv-@row.ProductId"
                                           type="number" name="store_@store.Id"
                                           value="@qty" min="0"
                                           class="w-16 text-center text-xs border border-neutral-200 rounded-sm px-2 py-1 focus:outline-none focus:border-neutral-400 bg-white
                                                  @(qty == 0 ? "text-red-600 border-red-200" : qty < row.LowStockThreshold ? "text-amber-600 border-amber-200" : "")" />
                                }
                            </td>
                        }

                        <!-- Save button -->
                        <td class="px-4 py-2 text-center">
                            <button form="inv-@row.ProductId" type="submit" data-no-loading="1"
                                    class="px-4 py-1.5 bg-neutral-900 text-white text-xs rounded-sm hover:bg-neutral-700 transition-colors">
                                Save
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    @if (Model.TotalPages > 1)
    {
        <div class="flex items-center justify-end gap-2 mt-4">
            @for (int pg = 1; pg <= Model.TotalPages; pg++)
            {
                <a asp-area="Admin" asp-controller="Inventory" asp-action="Index"
                   asp-route-page="@pg" asp-route-q="@Model.SearchQuery"
                   class="px-3 py-1.5 text-xs rounded-sm border transition-colors @(pg == Model.CurrentPage ? "bg-neutral-900 text-white border-neutral-900" : "border-neutral-200 text-neutral-600 hover:border-neutral-400")">
                    @pg
                </a>
            }
        </div>
    }
}
