@model List<SterlingLams.Web.Areas.Admin.Controllers.ReportsController.ProductRow>
@{
    ViewData["Title"] = "Best Sellers";
    var from = (DateTime)ViewBag.From;
    var to = (DateTime)ViewBag.To;
    var stores = ViewBag.Stores as List<SterlingLams.Web.Models.Domain.Store> ?? new();
    int? storeId = ViewBag.StoreId;
    var maxRev = Model.Any() ? Model.Max(r => r.Revenue) : 1;
}

@await Html.PartialAsync("_ReportTabs", "Products")

<form method="get" class="flex flex-wrap items-end gap-3 mb-6">
    <div><label class="block text-xs text-neutral-500 mb-1">From</label>
        <input type="date" name="from" value="@from.ToString("yyyy-MM-dd")" class="border border-neutral-200 rounded-sm px-3 py-1.5 text-sm" /></div>
    <div><label class="block text-xs text-neutral-500 mb-1">To</label>
        <input type="date" name="to" value="@to.ToString("yyyy-MM-dd")" class="border border-neutral-200 rounded-sm px-3 py-1.5 text-sm" /></div>
    <div><label class="block text-xs text-neutral-500 mb-1">Branch</label>
        <select name="storeId" class="border border-neutral-200 rounded-sm px-3 py-1.5 text-sm">
            <option value="">All branches</option>
            @foreach (var s in stores) { <option value="@s.Id" selected="@(storeId == s.Id)">@s.Name</option> }
        </select></div>
    <button class="px-4 py-1.5 bg-neutral-900 text-white text-sm rounded-sm hover:bg-neutral-700 transition-colors">Apply</button>
</form>

<div class="bg-white border border-neutral-100 rounded-sm overflow-hidden">
    <table class="w-full text-sm">
        <thead class="bg-neutral-50 text-neutral-500 text-xs uppercase tracking-wide">
            <tr>
                <th class="text-left font-medium px-4 py-3">#</th>
                <th class="text-left font-medium px-4 py-3">Product</th>
                <th class="text-right font-medium px-4 py-3">Units</th>
                <th class="text-right font-medium px-4 py-3">Revenue</th>
                <th class="px-4 py-3 w-1/3"></th>
            </tr>
        </thead>
        <tbody class="divide-y divide-neutral-100">
            @if (!Model.Any()) { <tr><td colspan="5" class="px-4 py-10 text-center text-neutral-400">No sales in range.</td></tr> }
            @{ int rank = 1; }
            @foreach (var r in Model)
            {
                <tr class="hover:bg-neutral-50">
                    <td class="px-4 py-2.5 text-neutral-400">@rank</td>
                    <td class="px-4 py-2.5 text-neutral-800">@r.Name @if (!string.IsNullOrEmpty(r.Sku)) { <span class="text-[10px] text-neutral-400 font-mono">@r.Sku</span> }</td>
                    <td class="px-4 py-2.5 text-right text-neutral-700">@r.Units</td>
                    <td class="px-4 py-2.5 text-right text-neutral-800">₦@r.Revenue.ToString("N0")</td>
                    <td class="px-4 py-2.5"><div class="h-2 bg-brand-100 rounded-full overflow-hidden"><div class="h-full bg-brand-500" style="width:@(maxRev > 0 ? (int)(r.Revenue / maxRev * 100) : 0)%"></div></div></td>
                </tr>
                rank++;
            }
        </tbody>
    </table>
</div>
