@model string
@{
    string Cls(string tab) => tab == Model
        ? "border-neutral-900 text-neutral-900"
        : "border-transparent text-neutral-400 hover:text-neutral-700";
}
<div class="flex items-center justify-between mb-6">
    <h1 class="text-lg font-medium text-neutral-800">Reports</h1>
</div>
<div class="flex gap-1 border-b border-neutral-200 mb-6">
    <a asp-area="Admin" asp-controller="Reports" asp-action="Sales"    class="px-4 py-2.5 text-xs font-medium border-b-2 transition-colors @Cls("Sales")">Sales</a>
    <a asp-area="Admin" asp-controller="Reports" asp-action="Products" class="px-4 py-2.5 text-xs font-medium border-b-2 transition-colors @Cls("Products")">Best Sellers</a>
    <a asp-area="Admin" asp-controller="Reports" asp-action="Stock"    class="px-4 py-2.5 text-xs font-medium border-b-2 transition-colors @Cls("Stock")">Stock</a>
</div>
