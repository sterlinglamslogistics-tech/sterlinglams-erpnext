@model SterlingLams.Web.Areas.Admin.ViewModels.AdminProductEditViewModel
@{
    var isNew = Model.Id == 0;
}

<div class="flex items-center justify-between mb-6">
    <div class="flex items-center gap-3">
        <a asp-area="Admin" asp-controller="Products" asp-action="Index"
           class="text-xs text-neutral-400 hover:text-neutral-700 transition-colors">← Products</a>
        <span class="text-neutral-200">/</span>
        <span class="text-xs text-neutral-600">@(isNew ? "New Product" : Model.Name)</span>
    </div>
    @if (!isNew && !string.IsNullOrEmpty(Model.Slug))
    {
        <a href="/Products/@Model.Slug" target="_blank"
           class="flex items-center gap-1.5 text-xs text-neutral-400 hover:text-neutral-900 transition-colors">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
            View on site
        </a>
    }
</div>

<div class="max-w-2xl">
    <form asp-area="Admin" asp-controller="Products" asp-action="Save" method="post" class="space-y-5">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <div class="bg-white rounded-sm border border-neutral-100 p-6 space-y-4">

            <!-- Name -->
            <div>
                <label asp-for="Name" class="block text-xs text-neutral-500 mb-1">Name <span class="text-red-400">*</span></label>
                <input asp-for="Name" class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400" />
                <span asp-validation-for="Name" class="text-xs text-red-500"></span>
            </div>

            <!-- Slug -->
            <div>
                <label asp-for="Slug" class="block text-xs text-neutral-500 mb-1">Slug (auto-generated if blank)</label>
                <input asp-for="Slug" class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm font-mono focus:outline-none focus:border-neutral-400" />
            </div>

            <!-- Price + Category -->
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label asp-for="Price" class="block text-xs text-neutral-500 mb-1">Price (₦) <span class="text-red-400">*</span></label>
                    <input asp-for="Price" type="number" step="0.01" min="0"
                           class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400" />
                    <span asp-validation-for="Price" class="text-xs text-red-500"></span>
                </div>
                <div>
                    <label asp-for="CategoryId" class="block text-xs text-neutral-500 mb-1">Category</label>
                    <select asp-for="CategoryId"
                            asp-items="@(new SelectList(Model.Categories, "Id", "Name"))"
                            class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400">
                        <option value="">— Select —</option>
                    </select>
                </div>
            </div>

            <!-- Short Description -->
            <div>
                <label asp-for="ShortDescription" class="block text-xs text-neutral-500 mb-1">Short Description <span class="text-neutral-300">(shown on product page)</span></label>
                <input asp-for="ShortDescription" class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400" />
            </div>

            <!-- Description -->
            <div>
                <label asp-for="Description" class="block text-xs text-neutral-500 mb-1">Full Description</label>
                <textarea asp-for="Description" rows="4"
                          class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400"></textarea>
            </div>

            <!-- Metal + Weight -->
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label asp-for="Colour" class="block text-xs text-neutral-500 mb-1">Colour</label>
                    <input asp-for="Colour" class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400" />
                </div>
                <div>
                    <label asp-for="Weight" class="block text-xs text-neutral-500 mb-1">Weight <span class="text-neutral-300">(e.g. 4.2g)</span></label>
                    <input asp-for="Weight" class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400" />
                </div>
            </div>

            <!-- ERPNext Item Code -->
            <div>
                <label asp-for="ErpNextItemCode" class="block text-xs text-neutral-500 mb-1">ERPNext Item Code</label>
                <input asp-for="ErpNextItemCode" type="text"
                       class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm font-mono focus:outline-none focus:border-neutral-400" />
            </div>

            <!-- Flags -->
            <div class="flex gap-6">
                <label class="flex items-center gap-2 text-sm text-neutral-600 cursor-pointer">
                    <input asp-for="IsActive" type="checkbox" class="rounded" />
                    Active
                </label>
                <label class="flex items-center gap-2 text-sm text-neutral-600 cursor-pointer">
                    <input asp-for="IsFeatured" type="checkbox" class="rounded" />
                    Featured
                </label>
                <label class="flex items-center gap-2 text-sm text-neutral-600 cursor-pointer">
                    <input asp-for="IsNewArrival" type="checkbox" class="rounded" />
                    New Arrival
                </label>
            </div>
        </div>

        <div class="flex gap-3">
            <button type="submit"
                    class="px-6 py-2.5 bg-neutral-900 text-white text-sm rounded-sm hover:bg-neutral-700 transition-colors">
                @(isNew ? "Create Product" : "Save Changes")
            </button>
            <a asp-area="Admin" asp-controller="Products" asp-action="Index"
               class="px-6 py-2.5 border border-neutral-200 text-neutral-600 text-sm rounded-sm hover:bg-neutral-50 transition-colors">
                Cancel
            </a>
        </div>
    </form>

    @if (!isNew)
    {
        <!-- ── Variants Tab ─────────────────────────────────────────────────── -->
        <div class="mt-6 bg-white rounded-sm border border-neutral-100 p-6">
            <h2 class="text-sm font-medium mb-1">Variants</h2>
            <p class="text-xs text-neutral-400 mb-5">Select attribute values that apply to this product, then click Generate to create all combinations.</p>

            @if (!Model.AllAttributes.Any())
            {
                <p class="text-xs text-neutral-400">
                    No attributes defined yet.
                    <a asp-area="Admin" asp-controller="Attributes" asp-action="Index"
                       class="underline hover:text-neutral-700">Go to Attributes</a> to create Colour, Alphabet, Length, etc.
                </p>
            }
            else
            {
                <!-- Attribute value selector -->
                <form asp-area="Admin" asp-controller="Products" asp-action="GenerateVariants"
                      asp-route-id="@Model.Id" method="post" class="space-y-5 mb-6">
                    @Html.AntiForgeryToken()

                    @foreach (var attr in Model.AllAttributes)
                    {
                        <div>
                            <p class="text-xs tracking-[0.1em] uppercase text-neutral-500 mb-2">@attr.Name</p>
                            <div class="flex flex-wrap gap-2">
                                @foreach (var val in attr.Values)
                                {
                                    var isSelected = Model.Variants.Any(v => v.AttributeLabels.Contains(val.Value));
                                    <label class="flex items-center gap-1.5 cursor-pointer">
                                        <input type="checkbox" name="selectedValueIds" value="@val.Id"
                                               @(isSelected ? "checked" : "")
                                               class="rounded border-neutral-300 text-neutral-900 accent-neutral-900" />
                                        @if (!string.IsNullOrEmpty(val.ColorHex))
                                        {
                                            <span class="w-4 h-4 rounded-full border border-neutral-200 inline-block"
                                                  style="background-color:@val.ColorHex"></span>
                                        }
                                        <span class="text-sm text-neutral-700">@val.Value</span>
                                    </label>
                                }
                            </div>
                        </div>
                    }

                    <button type="submit"
                            class="px-5 py-2 bg-neutral-900 text-white text-xs rounded-sm hover:bg-neutral-700 transition-colors">
                        ↺ Generate Variants
                    </button>
                </form>

                <!-- Existing variants table -->
                @if (Model.Variants.Any())
                {
                    var totalStock = Model.Variants.Where(v => v.IsActive).Sum(v => v.StockQuantity);
                    <div class="flex items-center gap-4 mb-4 p-3 bg-neutral-50 rounded-sm text-xs text-neutral-600">
                        <span><strong class="text-neutral-800">@Model.Variants.Count</strong> variants</span>
                        <span><strong class="@(totalStock == 0 ? "text-red-600" : totalStock < 5 ? "text-amber-600" : "text-emerald-600")">@totalStock</strong> total stock (active variants)</span>
                        <span class="text-neutral-400">@Model.Variants.Count(v => !v.IsActive) inactive</span>
                    </div>

                    @* Forms must live outside the table — inputs/buttons reference them via form= attribute *@
                    @foreach (var v in Model.Variants)
                    {
                        <form id="save-v-@v.Id"
                              asp-area="Admin" asp-controller="Products" asp-action="SaveVariant"
                              method="post" style="display:none">
                            @Html.AntiForgeryToken()
                            <input name="productId" value="@Model.Id" />
                            <input name="variantId" value="@v.Id" />
                        </form>
                        <form id="del-v-@v.Id"
                              asp-area="Admin" asp-controller="Products" asp-action="DeleteVariant"
                              method="post" style="display:none"
                              onsubmit="return confirm('Delete variant @v.Name?')">
                            @Html.AntiForgeryToken()
                            <input name="productId" value="@Model.Id" />
                            <input name="variantId" value="@v.Id" />
                        </form>
                    }

                    <table class="w-full text-sm border-t border-neutral-100">
                        <thead>
                            <tr class="text-left text-xs text-neutral-400 border-b border-neutral-100">
                                <th class="py-2 pr-4">Variant</th>
                                <th class="py-2 pr-4">SKU</th>
                                <th class="py-2 pr-4">Price Adj (₦)</th>
                                <th class="py-2 pr-4">Stock</th>
                                <th class="py-2 pr-4">Active</th>
                                <th class="py-2"></th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-neutral-50">
                            @foreach (var v in Model.Variants)
                            {
                                <tr>
                                    <td class="py-2 pr-4 text-xs text-neutral-700 font-medium">@v.Name</td>
                                    <td class="py-2 pr-4">
                                        <input form="save-v-@v.Id" name="sku" value="@v.Sku" placeholder="SKU"
                                               class="w-28 border border-neutral-200 rounded-sm px-2 py-1 text-xs focus:outline-none focus:border-neutral-400" />
                                    </td>
                                    <td class="py-2 pr-4">
                                        <input form="save-v-@v.Id" name="priceAdjustment" type="number" step="0.01"
                                               value="@v.PriceAdjustment" placeholder="0"
                                               class="w-24 border border-neutral-200 rounded-sm px-2 py-1 text-xs focus:outline-none focus:border-neutral-400" />
                                    </td>
                                    <td class="py-2 pr-4">
                                        <input form="save-v-@v.Id" name="stockQuantity" type="number" min="0"
                                               value="@v.StockQuantity"
                                               class="w-20 border border-neutral-200 rounded-sm px-2 py-1 text-xs focus:outline-none focus:border-neutral-400" />
                                    </td>
                                    <td class="py-2 pr-4">
                                        <input form="save-v-@v.Id" name="isActive" type="checkbox"
                                               @(v.IsActive ? "checked" : "") class="rounded accent-neutral-900" />
                                    </td>
                                    <td class="py-2 flex items-center gap-3">
                                        <button form="save-v-@v.Id" type="submit"
                                                class="text-xs text-neutral-500 hover:text-neutral-900 transition-colors">Save</button>
                                        <button form="del-v-@v.Id" type="submit"
                                                class="text-xs text-rose-400 hover:text-rose-700 transition-colors">Delete</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-xs text-neutral-400 mt-2">No variants yet. Select attribute values above and click Generate.</p>
                }
            }
        </div>

        <!-- Images -->
        <div class="mt-6 bg-white rounded-sm border border-neutral-100 p-6">
            <h2 class="text-sm font-medium mb-4">Product Images</h2>

            @if (Model.Images.Any())
            {
                <div class="flex flex-wrap gap-3 mb-4">
                    @foreach (var img in Model.Images)
                    {
                        <div class="relative group">
                            <img src="@img.Url" alt="@img.AltText" class="w-20 h-20 object-cover rounded border border-neutral-200" />
                            @if (img.IsPrimary)
                            {
                                <span class="absolute bottom-1 left-1 text-[9px] bg-neutral-900 text-white px-1 rounded">Primary</span>
                            }
                            <form asp-area="Admin" asp-controller="Products" asp-action="DeleteImage"
                                  asp-route-productId="@Model.Id" asp-route-imageId="@img.Id"
                                  method="post" class="absolute top-1 right-1 opacity-0 group-hover:opacity-100 transition-opacity">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="bg-red-500 text-white text-[10px] rounded w-5 h-5 flex items-center justify-center">×</button>
                            </form>
                        </div>
                    }
                </div>
            }

            <form asp-area="Admin" asp-controller="Products" asp-action="AddImage"
                  asp-route-id="@Model.Id" method="post" class="space-y-3">
                @Html.AntiForgeryToken()
                <div>
                    <label class="block text-xs text-neutral-500 mb-1">Image URL *</label>
                    <input name="imageUrl" type="url" required placeholder="https://…"
                           class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400" />
                </div>
                <div class="flex gap-4 items-end">
                    <div class="flex-1">
                        <label class="block text-xs text-neutral-500 mb-1">Alt Text</label>
                        <input name="altText" type="text"
                               class="w-full border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400" />
                    </div>
                    <label class="flex items-center gap-2 text-xs text-neutral-600 pb-2 cursor-pointer">
                        <input name="isPrimary" type="checkbox" class="accent-neutral-900" />
                        Set as primary
                    </label>
                    <button type="submit"
                            class="px-4 py-2 bg-neutral-900 text-white text-xs rounded-sm hover:bg-neutral-700 transition-colors pb-2">
                        Add Image
                    </button>
                </div>
            </form>
        </div>
    }
</div>
