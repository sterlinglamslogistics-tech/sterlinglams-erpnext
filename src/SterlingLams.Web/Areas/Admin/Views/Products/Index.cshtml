@model SterlingLams.Web.Areas.Admin.ViewModels.AdminProductListViewModel
@{
    ViewData["Title"] = "Products";
}

<!-- Toolbar -->
<div class="flex flex-col sm:flex-row sm:items-center gap-3 mb-6">
    <form method="get" class="flex gap-2 flex-1">
        <input type="text" name="q" value="@Model.SearchQuery"
               placeholder="Search products…"
               class="flex-1 border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400" />
        <button type="submit"
                class="px-4 py-2 bg-neutral-900 text-white text-xs rounded-sm hover:bg-neutral-700 transition-colors">
            Search
        </button>
    </form>

    <div class="flex gap-2 flex-wrap">
        <!-- Import from WooCommerce CSV -->
        <form asp-area="Admin" asp-controller="Products" asp-action="ImportFromWooCommerce"
              method="post" enctype="multipart/form-data"
              onsubmit="this.querySelector('button[type=submit]').disabled=true; this.querySelector('button[type=submit]').textContent='Importing…';">
            @Html.AntiForgeryToken()
            <label class="flex items-center gap-2 px-4 py-2 border border-emerald-400 text-emerald-700 text-xs rounded-sm hover:bg-emerald-50 transition-colors cursor-pointer">
                <span>↑ Import WooCommerce CSV</span>
                <input type="file" name="csvFile" accept=".csv" class="hidden"
                       onchange="this.closest('form').querySelector('button[type=submit]').click()" />
            </label>
            <button type="submit" class="hidden"></button>
        </form>
        <!-- Import from ERPNext (full product catalog upsert) -->
        <form asp-area="Admin" asp-controller="Products" asp-action="ImportFromERPNext" method="post"
              onsubmit="this.querySelector('button').disabled=true; this.querySelector('button').textContent='Importing…';">
            @Html.AntiForgeryToken()
            <button type="submit"
                    class="px-4 py-2 border border-amber-300 text-amber-700 text-xs rounded-sm hover:bg-amber-50 transition-colors">
                ↓ Import from ERPNext
            </button>
        </form>
        <!-- Sync inventory quantities only -->
        <form asp-area="Admin" asp-controller="Products" asp-action="SyncFromERPNext" method="post"
              onsubmit="this.querySelector('button').disabled=true; this.querySelector('button').textContent='Syncing…';">
            @Html.AntiForgeryToken()
            <button type="submit"
                    class="px-4 py-2 border border-neutral-300 text-neutral-700 text-xs rounded-sm hover:bg-neutral-50 transition-colors">
                ↺ Sync Inventory
            </button>
        </form>
        <a asp-area="Admin" asp-controller="Products" asp-action="Create"
           class="px-4 py-2 bg-neutral-900 text-white text-xs rounded-sm hover:bg-neutral-700 transition-colors">
            + New Product
        </a>
    </div>
</div>

<!-- Table -->
<div class="bg-white rounded-sm border border-neutral-100 overflow-hidden">
    <table class="w-full text-sm">
        <thead>
            <tr class="bg-neutral-50 border-b border-neutral-100">
                <th class="px-4 py-3 w-12"></th>
                <th class="text-left px-4 py-3 text-xs text-neutral-400 font-medium">Name</th>
                <th class="text-left px-4 py-3 text-xs text-neutral-400 font-medium">Category</th>
                <th class="text-left px-4 py-3 text-xs text-neutral-400 font-medium">Price</th>
                <th class="text-left px-4 py-3 text-xs text-neutral-400 font-medium">Status</th>
                <th class="text-right px-4 py-3 text-xs text-neutral-400 font-medium">Actions</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-neutral-50">
            @if (!Model.Products.Any())
            {
                <tr><td colspan="6" class="px-6 py-12 text-center text-neutral-400 text-sm">No products found. Use <strong>Import WooCommerce CSV</strong> to import your catalogue.</td></tr>
            }
            @foreach (var p in Model.Products)
            {
                var thumb = p.Images.OrderBy(i => i.SortOrder).FirstOrDefault()?.Url;
                <tr class="hover:bg-neutral-50 transition-colors">
                    <td class="px-4 py-2">
                        @if (!string.IsNullOrEmpty(thumb))
                        {
                            <img src="@thumb" alt="@p.Name"
                                 class="w-10 h-10 object-cover rounded-sm border border-neutral-100" />
                        }
                        else
                        {
                            <div class="w-10 h-10 rounded-sm bg-neutral-100 flex items-center justify-center">
                                <svg class="w-4 h-4 text-neutral-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                </svg>
                            </div>
                        }
                    </td>
                    <td class="px-4 py-3">
                        <p class="text-xs font-medium text-neutral-800">@p.Name</p>
                        <div class="flex gap-1 mt-0.5">
                            @if (p.IsFeatured) { <span class="text-[9px] bg-amber-50 text-amber-700 px-1.5 py-0.5 rounded">Featured</span> }
                            @if (p.IsNewArrival) { <span class="text-[9px] bg-blue-50 text-blue-700 px-1.5 py-0.5 rounded">New</span> }
                        </div>
                    </td>
                    <td class="px-4 py-3 text-xs text-neutral-500">@(p.Category?.Name ?? "—")</td>
                    <td class="px-4 py-3 text-xs font-medium">₦@p.Price.ToString("N0")</td>
                    <td class="px-4 py-3">
                        @if (p.IsActive)
                        {
                            <span class="text-[10px] bg-emerald-50 text-emerald-700 px-2 py-0.5 rounded-full">Active</span>
                        }
                        else
                        {
                            <span class="text-[10px] bg-neutral-100 text-neutral-500 px-2 py-0.5 rounded-full">Inactive</span>
                        }
                    </td>
                    <td class="px-4 py-3 text-right">
                        <div class="flex items-center justify-end gap-3">
                            <a asp-area="Admin" asp-controller="Products" asp-action="Edit" asp-route-id="@p.Id"
                               class="text-xs text-neutral-500 hover:text-neutral-900 transition-colors">Edit</a>
                            <form asp-area="Admin" asp-controller="Products" asp-action="Duplicate"
                                  asp-route-id="@p.Id" method="post" class="inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" data-no-loading="1"
                                        class="text-xs text-neutral-400 hover:text-neutral-700 transition-colors">Copy</button>
                            </form>
                            <form asp-area="Admin" asp-controller="Products" asp-action="ToggleActive"
                                  asp-route-id="@p.Id" method="post" class="inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" data-no-loading="1"
                                        class="text-xs text-neutral-400 hover:text-neutral-700 transition-colors">
                                    @(p.IsActive ? "Deactivate" : "Activate")
                                </button>
                            </form>
                            <form asp-area="Admin" asp-controller="Products" asp-action="Delete"
                                  asp-route-id="@p.Id" method="post" class="inline"
                                  onsubmit="return confirm('Delete @Html.Raw(p.Name.Replace("'","\\'")), are you sure?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" data-no-loading="1"
                                        class="text-xs text-rose-400 hover:text-rose-700 transition-colors">Delete</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Pagination -->
@if (Model.TotalPages > 1)
{
    <div class="flex items-center justify-end gap-2 mt-4">
        @for (int p = 1; p <= Model.TotalPages; p++)
        {
            <a asp-area="Admin" asp-controller="Products" asp-action="Index"
               asp-route-page="@p" asp-route-q="@Model.SearchQuery"
               class="px-3 py-1.5 text-xs rounded-sm border transition-colors @(p == Model.CurrentPage ? "bg-neutral-900 text-white border-neutral-900" : "border-neutral-200 text-neutral-600 hover:border-neutral-400")">
                @p
            </a>
        }
    </div>
}
