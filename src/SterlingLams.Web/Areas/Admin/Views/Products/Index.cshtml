@model SterlingLams.Web.Areas.Admin.ViewModels.AdminProductListViewModel
@{
    ViewData["Title"] = "Products";
    bool hasFilters = !string.IsNullOrEmpty(Model.SearchQuery) ||
                      !string.IsNullOrEmpty(Model.CategoryFilter) ||
                      !string.IsNullOrEmpty(Model.StatusFilter) ||
                      Model.MinPrice.HasValue || Model.MaxPrice.HasValue;
}

<!-- ── Action buttons (OUTSIDE the filter form — nested forms break HTML) -->
<div class="flex justify-end gap-2 flex-wrap mb-4">
    <form asp-area="Admin" asp-controller="Products" asp-action="ImportFromWooCommerce"
          method="post" enctype="multipart/form-data"
          onsubmit="this.querySelector('button[type=submit]').disabled=true;this.querySelector('button[type=submit]').textContent='Importing…';">
        @Html.AntiForgeryToken()
        <label class="flex items-center gap-2 px-4 py-2 border border-emerald-400 text-emerald-700 text-xs rounded-sm hover:bg-emerald-50 transition-colors cursor-pointer">
            <span>↑ Import WooCommerce CSV</span>
            <input type="file" name="csvFile" accept=".csv" class="hidden"
                   onchange="this.closest('form').querySelector('button[type=submit]').click()" />
        </label>
        <button type="submit" class="hidden"></button>
    </form>
    <a asp-area="Admin" asp-controller="Products" asp-action="Create"
       class="px-4 py-2 bg-neutral-900 text-white text-xs rounded-sm hover:bg-neutral-700 transition-colors">
        + New Product
    </a>
</div>

<!-- ── Filter form (standalone — no nested forms) -->
<form method="get" class="bg-white rounded-sm border border-neutral-100 p-4 mb-4 space-y-3">

    <!-- Row 1: Name search -->
    <div class="flex gap-2">
        <input type="text" name="q" value="@Model.SearchQuery"
               placeholder="Search by product name…"
               class="flex-1 border border-neutral-200 rounded-sm px-3 py-2 text-sm focus:outline-none focus:border-neutral-400" />
        <button type="submit"
                class="px-4 py-2 bg-neutral-900 text-white text-xs rounded-sm hover:bg-neutral-700 transition-colors">
            Search
        </button>
        @if (hasFilters)
        {
            <a asp-area="Admin" asp-controller="Products" asp-action="Index"
               class="px-4 py-2 border border-neutral-300 text-neutral-500 text-xs rounded-sm hover:border-neutral-500 transition-colors whitespace-nowrap">
                ✕ Clear All
            </a>
        }
    </div>

    <!-- Row 2: Category · Status · Price -->
    <div class="flex flex-wrap gap-4 items-end">

        <!-- Category -->
        <div class="flex flex-col gap-1">
            <label class="text-[10px] text-neutral-400 uppercase tracking-widest">Category</label>
            <select name="category"
                    class="border border-neutral-200 rounded-sm px-3 py-2 text-xs focus:outline-none focus:border-neutral-400 bg-white min-w-[140px]">
                <option value="">All Categories</option>
                @foreach (var cat in Model.AvailableCategories)
                {
                    <option value="@cat.Slug" selected="@(Model.CategoryFilter == cat.Slug)">@cat.Name</option>
                }
            </select>
        </div>

        <!-- Status -->
        <div class="flex flex-col gap-1">
            <label class="text-[10px] text-neutral-400 uppercase tracking-widest">Status</label>
            <select name="status"
                    class="border border-neutral-200 rounded-sm px-3 py-2 text-xs focus:outline-none focus:border-neutral-400 bg-white min-w-[130px]">
                <option value="">All Status</option>
                <option value="active"   selected="@(Model.StatusFilter == "active")">Active</option>
                <option value="inactive" selected="@(Model.StatusFilter == "inactive")">Inactive</option>
                <option value="featured" selected="@(Model.StatusFilter == "featured")">Featured</option>
                <option value="new"      selected="@(Model.StatusFilter == "new")">New Arrival</option>
            </select>
        </div>

        <!-- Type -->
        <div class="flex flex-col gap-1">
            <label class="text-[10px] text-neutral-400 uppercase tracking-widest">Type</label>
            <select name="type"
                    class="border border-neutral-200 rounded-sm px-3 py-2 text-xs focus:outline-none focus:border-neutral-400 bg-white min-w-[130px]">
                <option value="">All Types</option>
                <option value="simple"   selected="@(Model.TypeFilter == "simple")">Simple</option>
                <option value="variable" selected="@(Model.TypeFilter == "variable")">Variable</option>
            </select>
        </div>

        <!-- Price range -->
        <div class="flex flex-col gap-1">
            <label class="text-[10px] text-neutral-400 uppercase tracking-widest">Price (₦)</label>
            <div class="flex items-center gap-1.5">
                <input type="number" name="minPrice" value="@Model.MinPrice" placeholder="Min"
                       class="w-24 border border-neutral-200 rounded-sm px-2 py-2 text-xs focus:outline-none focus:border-neutral-400" />
                <span class="text-neutral-300 text-xs">—</span>
                <input type="number" name="maxPrice" value="@Model.MaxPrice" placeholder="Max"
                       class="w-24 border border-neutral-200 rounded-sm px-2 py-2 text-xs focus:outline-none focus:border-neutral-400" />
            </div>
        </div>

        <!-- Apply button -->
        <button type="submit"
                class="px-6 py-2 bg-neutral-900 text-white text-xs rounded-sm hover:bg-neutral-700 transition-colors self-end">
            Apply Filters
        </button>

        <!-- Result count -->
        <p class="text-xs text-neutral-400 self-end ml-auto">
            <strong class="text-neutral-700">@Model.TotalCount</strong>
            product@(Model.TotalCount == 1 ? "" : "s")
            @if (hasFilters) { <span class="text-neutral-400">matching filters</span> }
        </p>
    </div>

    <!-- Active filter chips -->
    @if (hasFilters)
    {
        <div class="flex flex-wrap gap-2 pt-1 border-t border-neutral-50">
            @if (!string.IsNullOrEmpty(Model.SearchQuery))
            {
                <span class="text-[11px] bg-neutral-100 text-neutral-600 px-3 py-1 rounded-full">
                    Name: "@Model.SearchQuery"
                </span>
            }
            @if (!string.IsNullOrEmpty(Model.CategoryFilter))
            {
                <span class="text-[11px] bg-neutral-100 text-neutral-600 px-3 py-1 rounded-full">
                    Category: @(Model.AvailableCategories.FirstOrDefault(c => c.Slug == Model.CategoryFilter)?.Name ?? Model.CategoryFilter)
                </span>
            }
            @if (!string.IsNullOrEmpty(Model.StatusFilter))
            {
                <span class="text-[11px] bg-neutral-100 text-neutral-600 px-3 py-1 rounded-full">
                    Status: @System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(Model.StatusFilter)
                </span>
            }
            @if (Model.MinPrice.HasValue || Model.MaxPrice.HasValue)
            {
                <span class="text-[11px] bg-neutral-100 text-neutral-600 px-3 py-1 rounded-full">
                    Price: ₦@(Model.MinPrice?.ToString("N0") ?? "0") — ₦@(Model.MaxPrice?.ToString("N0") ?? "∞")
                </span>
            }
        </div>
    }
</form>

<!-- ── Products table -->
<div class="bg-white rounded-sm border border-neutral-100 overflow-hidden">
    <table class="w-full text-sm">
        <thead>
            <tr class="bg-neutral-50 border-b border-neutral-100">
                <th class="px-4 py-3 w-14"></th>
                <th class="text-left px-4 py-3 text-xs text-neutral-400 font-medium">Name</th>
                <th class="text-left px-4 py-3 text-xs text-neutral-400 font-medium">Category</th>
                <th class="text-left px-4 py-3 text-xs text-neutral-400 font-medium">Price</th>
                <th class="text-left px-4 py-3 text-xs text-neutral-400 font-medium">Status</th>
                <th class="text-right px-4 py-3 text-xs text-neutral-400 font-medium">Actions</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-neutral-50">
            @if (!Model.Products.Any())
            {
                <tr>
                    <td colspan="6" class="px-6 py-16 text-center text-neutral-400 text-sm">
                        @if (hasFilters)
                        {
                            <span>No products match your filters. <a asp-area="Admin" asp-controller="Products" asp-action="Index" class="underline hover:text-neutral-700">Clear all filters</a></span>
                        }
                        else
                        {
                            <span>No products yet. Use <strong>↑ Import WooCommerce CSV</strong> above to import your catalogue.</span>
                        }
                    </td>
                </tr>
            }
            @foreach (var p in Model.Products)
            {
                var thumb = p.Images.OrderBy(i => i.SortOrder).FirstOrDefault()?.Url;
                <tr class="hover:bg-neutral-50 transition-colors">
                    <!-- Thumbnail -->
                    <td class="px-4 py-2">
                        @if (!string.IsNullOrEmpty(thumb))
                        {
                            <img src="@thumb" alt="@p.Name"
                                 class="w-12 h-12 object-cover rounded-sm border border-neutral-100"
                                 onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                            <div class="w-12 h-12 rounded-sm bg-neutral-100 items-center justify-center hidden">
                                <svg class="w-4 h-4 text-neutral-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                </svg>
                            </div>
                        }
                        else
                        {
                            <div class="w-12 h-12 rounded-sm bg-neutral-100 flex items-center justify-center">
                                <svg class="w-4 h-4 text-neutral-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                </svg>
                            </div>
                        }
                    </td>

                    <!-- Name -->
                    <td class="px-4 py-3">
                        <p class="text-xs font-medium text-neutral-800">@p.Name</p>
                        <div class="flex gap-1 mt-0.5 flex-wrap items-center">
                            @if (p.Variants.Count > 0)
                            {
                                <span class="text-[10px] bg-indigo-50 text-indigo-700 px-2 py-0.5 rounded-full font-medium">@p.Variants.Count variant@(p.Variants.Count == 1 ? "" : "s")</span>
                            }
                            @if (p.IsFeatured)   { <span class="text-[9px] bg-amber-50 text-amber-700 px-1.5 py-0.5 rounded">Featured</span> }
                            @if (p.IsNewArrival) { <span class="text-[9px] bg-blue-50 text-blue-700 px-1.5 py-0.5 rounded">New</span> }
                            @if (!string.IsNullOrEmpty(p.Sku)) { <span class="text-[9px] text-neutral-400 font-mono">@p.Sku</span> }
                        </div>
                    </td>

                    <td class="px-4 py-3 text-xs text-neutral-500">@(p.Category?.Name ?? "—")</td>
                    <td class="px-4 py-3 text-xs font-medium">₦@p.Price.ToString("N0")</td>

                    <td class="px-4 py-3">
                        @if (p.IsActive)
                        {
                            <span class="text-[10px] bg-emerald-50 text-emerald-700 px-2 py-0.5 rounded-full">Active</span>
                        }
                        else
                        {
                            <span class="text-[10px] bg-neutral-100 text-neutral-500 px-2 py-0.5 rounded-full">Inactive</span>
                        }
                    </td>

                    <td class="px-4 py-3 text-right">
                        <div class="flex items-center justify-end gap-3">
                            <a asp-area="Admin" asp-controller="Products" asp-action="Edit" asp-route-id="@p.Id"
                               class="text-xs text-neutral-500 hover:text-neutral-900 transition-colors">Edit</a>
                            <form asp-area="Admin" asp-controller="Products" asp-action="Duplicate"
                                  asp-route-id="@p.Id" method="post" class="inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" data-no-loading="1"
                                        class="text-xs text-neutral-400 hover:text-neutral-700 transition-colors">Copy</button>
                            </form>
                            <form asp-area="Admin" asp-controller="Products" asp-action="ToggleActive"
                                  asp-route-id="@p.Id" method="post" class="inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" data-no-loading="1"
                                        class="text-xs text-neutral-400 hover:text-neutral-700 transition-colors">
                                    @(p.IsActive ? "Deactivate" : "Activate")
                                </button>
                            </form>
                            <form asp-area="Admin" asp-controller="Products" asp-action="Delete"
                                  asp-route-id="@p.Id" method="post" class="inline"
                                  onsubmit="return confirm('Delete @Html.Raw(p.Name.Replace("'","\\'")), are you sure?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" data-no-loading="1"
                                        class="text-xs text-rose-400 hover:text-rose-700 transition-colors">Delete</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Pagination — windowed, preserves all active filters -->
@if (Model.TotalPages > 1)
{
    var cur = Model.CurrentPage;
    var last = Model.TotalPages;
    var start = Math.Max(1, cur - 2);
    var end = Math.Min(last, cur + 2);

    Func<int, Dictionary<string, string>> rd = pg => new Dictionary<string, string>
    {
        ["page"] = pg.ToString(),
        ["q"] = Model.SearchQuery ?? "",
        ["category"] = Model.CategoryFilter ?? "",
        ["status"] = Model.StatusFilter ?? "",
        ["type"] = Model.TypeFilter ?? "",
        ["minPrice"] = Model.MinPrice?.ToString() ?? "",
        ["maxPrice"] = Model.MaxPrice?.ToString() ?? "",
    };
    var baseCls = "px-3 py-1.5 text-xs rounded-sm border border-neutral-200 text-neutral-600 hover:border-neutral-400 transition-colors";

    <div class="flex items-center justify-center gap-1.5 mt-4 flex-wrap">
        <span class="text-[11px] text-neutral-400 mr-1">Page @cur of @last</span>

        @if (cur > 1)
        {
            <a asp-area="Admin" asp-controller="Products" asp-action="Index" asp-all-route-data="rd(1)" class="@baseCls">« First</a>
            <a asp-area="Admin" asp-controller="Products" asp-action="Index" asp-all-route-data="rd(cur - 1)" class="@baseCls">‹ Prev</a>
        }

        @if (start > 1)
        {
            <a asp-area="Admin" asp-controller="Products" asp-action="Index" asp-all-route-data="rd(1)" class="@baseCls">1</a>
            @if (start > 2) { <span class="px-1 text-neutral-300">…</span> }
        }

        @for (int pg = start; pg <= end; pg++)
        {
            <a asp-area="Admin" asp-controller="Products" asp-action="Index" asp-all-route-data="rd(pg)"
               class="px-3 py-1.5 text-xs rounded-sm border transition-colors @(pg == cur ? "bg-neutral-900 text-white border-neutral-900" : "border-neutral-200 text-neutral-600 hover:border-neutral-400")">@pg</a>
        }

        @if (end < last)
        {
            @if (end < last - 1) { <span class="px-1 text-neutral-300">…</span> }
            <a asp-area="Admin" asp-controller="Products" asp-action="Index" asp-all-route-data="rd(last)" class="@baseCls">@last</a>
        }

        @if (cur < last)
        {
            <a asp-area="Admin" asp-controller="Products" asp-action="Index" asp-all-route-data="rd(cur + 1)" class="@baseCls">Next ›</a>
            <a asp-area="Admin" asp-controller="Products" asp-action="Index" asp-all-route-data="rd(last)" class="@baseCls">Last »</a>
        }
    </div>
}
