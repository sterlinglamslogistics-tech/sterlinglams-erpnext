<footer class="bg-neutral-900 text-white mt-24">
    <div class="max-w-7xl mx-auto px-6 py-16">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-12">
            <!-- Brand -->
            <div class="md:col-span-1">
                <span class="font-cormorant text-2xl font-light tracking-[0.3em] uppercase">
                    Sterlin Glams
                </span>
                <p class="mt-4 text-neutral-400 text-sm leading-relaxed font-light">
                    Timeless luxury jewellery crafted with the finest materials. Three stores across Lagos.
                </p>
                <div class="flex gap-4 mt-6">
                    <a href="#" aria-label="Instagram" class="text-neutral-400 hover:text-white transition-colors">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
